ACCESS_TOKEN={Facebook GraphAPI access token}
BUSINESS_ACC_ID={Instagram Business Id}
GITHUB_PAT={Github Personal Access Token}
GITHUB_REPO_PATH={Github API link to the repository where videos are stored. I.e. "https://api.github.com/repos/{USER}/{REPO}/contents"}

# --- Automation Pipeline Keys ---
PEXELS_API_KEY={Free API key from https://www.pexels.com/api/}
LLM_API_KEY={Gemini or OpenAI API key for quote curation + caption generation}
LLM_PROVIDER=gemini